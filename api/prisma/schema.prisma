// ============================================================
// PharmaNest BD — Full Database Schema
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  CUSTOMER
  ADMIN
  PHARMACIST
  STAFF
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
}

enum DosageForm {
  TABLET
  CAPSULE
  SYRUP
  SUSPENSION
  INJECTION
  CREAM
  OINTMENT
  GEL
  DROPS
  INHALER
  SUPPOSITORY
  POWDER
  SOLUTION
  SPRAY
  DEVICE
  OTHER
}

enum OrderStatus {
  PENDING
  PRESCRIPTION_REVIEW_PENDING
  PRESCRIPTION_APPROVED
  PRESCRIPTION_REJECTED
  PAYMENT_PENDING
  PAYMENT_VERIFICATION_PENDING
  PROCESSING
  PACKED
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  FAILED
}

enum PaymentMethod {
  BKASH
  NAGAD
  ROCKET
  COD
}

enum PaymentStatus {
  PENDING
  SUBMITTED
  VERIFIED
  REJECTED
  COD_PENDING
  PAID
  REFUNDED
  FAILED
}

enum PrescriptionStatus {
  PENDING
  APPROVED
  PARTIALLY_APPROVED
  REJECTED
  NEEDS_CLARIFICATION
  EXPIRED
}

enum AddressType {
  HOME
  OFFICE
  OTHER
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
  LOGIN
  LOGOUT
  VERIFY
  STATUS_CHANGE
}

// ============================================================
// MODELS
// ============================================================

model User {
  id              String     @id @default(cuid())
  email           String     @unique
  phone           String     @unique
  passwordHash    String     @map("password_hash")
  refreshTokenHash String?   @map("refresh_token_hash")
  fullName        String     @map("full_name")
  role            UserRole   @default(CUSTOMER)
  status          UserStatus @default(ACTIVE)
  avatar          String?
  emailVerifiedAt DateTime?  @map("email_verified_at")
  phoneVerifiedAt DateTime?  @map("phone_verified_at")
  lastLoginAt     DateTime?  @map("last_login_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  addresses             Address[]
  orders                Order[]
  prescriptions         Prescription[]       @relation("UserPrescriptions")
  reviewedPrescriptions Prescription[]       @relation("PrescriptionReviewer")
  verifiedPayments      PaymentSubmission[]  @relation("PaymentVerifier")
  cart                  Cart?
  wishlist              Wishlist?
  auditLogs             AuditLog[]
  orderStatusLogs       OrderStatusLog[]

  @@index([role])
  @@index([status])
  @@index([email])
  @@map("users")
}

model Address {
  id             String      @id @default(cuid())
  userId         String      @map("user_id")
  label          AddressType @default(HOME)
  recipientName  String      @map("recipient_name")
  phone          String
  alternatePhone String?     @map("alternate_phone")
  division       String
  district       String
  upazilaThana   String      @map("upazila_thana")
  postcode       String
  area           String
  addressLine    String      @map("address_line")
  houseFlat      String      @map("house_flat")
  landmark       String?
  deliveryNote   String?     @map("delivery_note")
  isDefault      Boolean     @default(false) @map("is_default")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId])
  @@index([division, district])
  @@map("addresses")
}

model Category {
  id          String   @id @default(cuid())
  parentId    String?  @map("parent_id")
  name        String
  slug        String   @unique
  description String?
  imageUrl    String?  @map("image_url")
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  parent   Category?  @relation("CategoryParent", fields: [parentId], references: [id])
  children Category[] @relation("CategoryParent")
  products Product[]

  @@index([parentId])
  @@index([isActive, sortOrder])
  @@map("categories")
}

model Brand {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  manufacturerName String?  @map("manufacturer_name")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  products Product[]

  @@map("brands")
}

model Product {
  id                     String        @id @default(cuid())
  categoryId             String        @map("category_id")
  brandId                String?       @map("brand_id")
  name                   String
  slug                   String        @unique
  genericName            String        @map("generic_name")
  manufacturerName       String        @map("manufacturer_name")
  dosageForm             DosageForm    @default(TABLET) @map("dosage_form")
  strength               String
  packSize               String        @map("pack_size")
  shortDescription       String?       @map("short_description")
  description            String?
  indications            String?
  dosageInstructions     String?       @map("dosage_instructions")
  sideEffects            String?       @map("side_effects")
  warnings               String?
  storageInfo            String?       @map("storage_info")
  price                  Decimal       @db.Decimal(10, 2)
  discountPrice          Decimal?      @map("discount_price") @db.Decimal(10, 2)
  costPrice              Decimal?      @map("cost_price") @db.Decimal(10, 2)
  sku                    String?       @unique
  barcode                String?
  stockQty               Int           @default(0) @map("stock_qty")
  minOrderQty            Int           @default(1) @map("min_order_qty")
  maxOrderQty            Int           @default(99) @map("max_order_qty")
  isPrescriptionRequired Boolean       @default(false) @map("is_prescription_required")
  status                 ProductStatus @default(ACTIVE)
  isFeatured             Boolean       @default(false) @map("is_featured")
  metaTitle              String?       @map("meta_title")
  metaDescription        String?       @map("meta_description")
  createdAt              DateTime      @default(now()) @map("created_at")
  updatedAt              DateTime      @updatedAt @map("updated_at")

  category     Category  @relation(fields: [categoryId], references: [id])
  brand        Brand?               @relation(fields: [brandId], references: [id])
  images       ProductImage[]
  tags         ProductTag[]
  alternatives ProductAlternative[] @relation("ProductAlternatives")
  alternateOf  ProductAlternative[] @relation("AlternativeProduct")
  cartItems    CartItem[]
  wishItems    WishlistItem[]
  orderItems   OrderItem[]
  rxItems      PrescriptionItem[]

  @@index([categoryId])
  @@index([brandId])
  @@index([status, isFeatured])
  @@index([isPrescriptionRequired])
  @@index([name, genericName])
  @@index([price])
  @@map("products")
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String  @map("product_id")
  imageUrl  String  @map("image_url")
  altText   String? @map("alt_text")
  sortOrder Int     @default(0) @map("sort_order")
  isPrimary Boolean @default(false) @map("is_primary")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

model ProductTag {
  id        String @id @default(cuid())
  productId String @map("product_id")
  tag       String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, tag])
  @@index([tag])
  @@map("product_tags")
}

model ProductAlternative {
  id                   String @id @default(cuid())
  productId            String @map("product_id")
  alternativeProductId String @map("alternative_product_id")

  product     Product @relation("ProductAlternatives", fields: [productId], references: [id], onDelete: Cascade)
  alternative Product @relation("AlternativeProduct", fields: [alternativeProductId], references: [id], onDelete: Cascade)

  @@unique([productId, alternativeProductId])
  @@map("product_alternatives")
}

// ============================================================
// CART & WISHLIST
// ============================================================

model Cart {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@map("carts")
}

model CartItem {
  id                String   @id @default(cuid())
  cartId            String   @map("cart_id")
  productId         String   @map("product_id")
  quantity          Int      @default(1)
  unitPriceSnapshot Decimal? @map("unit_price_snapshot") @db.Decimal(10, 2)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
  @@map("cart_items")
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items WishlistItem[]

  @@map("wishlists")
}

model WishlistItem {
  id         String   @id @default(cuid())
  wishlistId String   @map("wishlist_id")
  productId  String   @map("product_id")
  createdAt  DateTime @default(now()) @map("created_at")

  wishlist Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])

  @@unique([wishlistId, productId])
  @@map("wishlist_items")
}

// ============================================================
// PRESCRIPTIONS
// ============================================================

model Prescription {
  id             String             @id @default(cuid())
  userId         String             @map("user_id")
  orderId        String?            @map("order_id")
  fileUrl        String?            @map("file_url")
  fileName       String?            @map("file_name")
  fileType       String?            @map("file_type")
  patientName    String             @map("patient_name")
  doctorName     String             @map("doctor_name")
  issuedDate     DateTime?          @map("issued_date")
  notes          String?
  status         PrescriptionStatus @default(PENDING)
  pharmacistNote String?            @map("pharmacist_note")
  reviewedById   String?            @map("reviewed_by_id")
  reviewedAt     DateTime?          @map("reviewed_at")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  user       User               @relation("UserPrescriptions", fields: [userId], references: [id])
  reviewedBy User?              @relation("PrescriptionReviewer", fields: [reviewedById], references: [id])
  orders     Order[]
  items      PrescriptionItem[]

  @@index([userId])
  @@index([status])
  @@index([orderId])
  @@map("prescriptions")
}

model PrescriptionItem {
  id               String  @id @default(cuid())
  prescriptionId   String  @map("prescription_id")
  productId        String  @map("product_id")
  requestedQty     Int?    @map("requested_qty")
  approvedQty      Int?    @map("approved_qty")
  status           String?
  note             String?

  prescription Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id])

  @@map("prescription_items")
}

// ============================================================
// ORDERS
// ============================================================

model Order {
  id               String        @id @default(cuid())
  userId           String        @map("user_id")
  addressId        String?       @map("address_id")
  prescriptionId   String?       @map("prescription_id")
  orderNumber      String        @unique @map("order_number")
  subtotal         Decimal       @db.Decimal(10, 2)
  discountTotal    Decimal       @default(0) @map("discount_total") @db.Decimal(10, 2)
  deliveryFee      Decimal       @default(0) @map("delivery_fee") @db.Decimal(10, 2)
  total            Decimal       @db.Decimal(10, 2)
  currency         String        @default("BDT")
  paymentMethod    PaymentMethod @map("payment_method")
  paymentStatus    PaymentStatus @default(PENDING) @map("payment_status")
  orderStatus      OrderStatus   @default(PENDING) @map("order_status")
  customerNote     String?       @map("customer_note")
  adminNote        String?       @map("admin_note")
  couponCode       String?       @map("coupon_code")
  placedAt         DateTime      @default(now()) @map("placed_at")
  approvedAt       DateTime?     @map("approved_at")
  shippedAt        DateTime?     @map("shipped_at")
  deliveredAt      DateTime?     @map("delivered_at")
  cancelledAt      DateTime?     @map("cancelled_at")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  user         User                @relation(fields: [userId], references: [id])
  address      Address?            @relation(fields: [addressId], references: [id])
  prescription Prescription?       @relation(fields: [prescriptionId], references: [id])
  items        OrderItem[]
  payments     PaymentSubmission[]
  statusLogs   OrderStatusLog[]

  @@index([userId])
  @@index([orderStatus])
  @@index([paymentStatus])
  @@index([paymentMethod])
  @@index([placedAt])
  @@map("orders")
}

model OrderItem {
  id                   String   @id @default(cuid())
  orderId              String   @map("order_id")
  productId            String?  @map("product_id")
  productNameSnapshot  String   @map("product_name_snapshot")
  genericNameSnapshot  String?  @map("generic_name_snapshot")
  manufacturerSnapshot String?  @map("manufacturer_snapshot")
  strengthSnapshot     String?  @map("strength_snapshot")
  packSizeSnapshot     String?  @map("pack_size_snapshot")
  skuSnapshot          String?  @map("sku_snapshot")
  imageSnapshot        String?  @map("image_snapshot")
  unitPrice            Decimal  @map("unit_price") @db.Decimal(10, 2)
  discountAmount       Decimal  @default(0) @map("discount_amount") @db.Decimal(10, 2)
  quantity             Int
  lineTotal            Decimal  @map("line_total") @db.Decimal(10, 2)
  requiresPrescription Boolean  @default(false) @map("requires_prescription")
  createdAt            DateTime @default(now()) @map("created_at")

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@map("order_items")
}

model PaymentSubmission {
  id               String        @id @default(cuid())
  orderId          String        @map("order_id")
  method           PaymentMethod
  senderNumber     String?       @map("sender_number")
  transactionId    String?       @map("transaction_id")
  amount           Decimal       @db.Decimal(10, 2)
  paymentTime      DateTime?     @map("payment_time")
  screenshotUrl    String?       @map("screenshot_url")
  status           PaymentStatus @default(PENDING)
  verificationNote String?       @map("verification_note")
  verifiedById     String?       @map("verified_by_id")
  verifiedAt       DateTime?     @map("verified_at")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  order      Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  verifiedBy User? @relation("PaymentVerifier", fields: [verifiedById], references: [id])

  @@index([orderId])
  @@index([status])
  @@map("payment_submissions")
}

model OrderStatusLog {
  id          String      @id @default(cuid())
  orderId     String      @map("order_id")
  oldStatus   OrderStatus? @map("old_status")
  newStatus   OrderStatus  @map("new_status")
  note        String?
  changedById String?     @map("changed_by_id")
  createdAt   DateTime    @default(now()) @map("created_at")

  order     Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changedBy User? @relation(fields: [changedById], references: [id])

  @@index([orderId])
  @@map("order_status_logs")
}

// ============================================================
// SETTINGS
// ============================================================

model AppSetting {
  id                        String   @id @default(cuid())
  storeName                 String   @default("PharmaNest BD") @map("store_name")
  supportPhone              String?  @map("support_phone")
  supportEmail              String?  @map("support_email")
  storeAddress              String?  @map("store_address")
  bkashNumber               String?  @map("bkash_number")
  nagadNumber               String?  @map("nagad_number")
  rocketNumber              String?  @map("rocket_number")
  codEnabled                Boolean  @default(true) @map("cod_enabled")
  baseDeliveryCharge        Decimal  @default(60) @map("base_delivery_charge") @db.Decimal(10, 2)
  dhakaDeliveryCharge       Decimal  @default(60) @map("dhaka_delivery_charge") @db.Decimal(10, 2)
  outsideDhakaCharge        Decimal  @default(120) @map("outside_dhaka_charge") @db.Decimal(10, 2)
  freeDeliveryThreshold     Decimal? @map("free_delivery_threshold") @db.Decimal(10, 2)
  prescriptionPolicyText    String?  @map("prescription_policy_text")
  footerText                String?  @map("footer_text")
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

// ============================================================
// AUDIT
// ============================================================

model AuditLog {
  id          String      @id @default(cuid())
  actorUserId String?     @map("actor_user_id")
  actionType  AuditAction @map("action_type")
  entityType  String      @map("entity_type")
  entityId    String?     @map("entity_id")
  detailsJson Json?       @map("details_json")
  createdAt   DateTime    @default(now()) @map("created_at")

  actor User? @relation(fields: [actorUserId], references: [id])

  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([actionType])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================================
// BANGLADESH LOCATIONS
// ============================================================

model Division {
  id        String     @id @default(cuid())
  name      String     @unique
  nameBn    String     @map("name_bn")
  districts District[]

  @@map("divisions")
}

model District {
  id         String    @id @default(cuid())
  divisionId String    @map("division_id")
  name       String
  nameBn     String    @map("name_bn")
  upazilas   Upazila[]

  division Division @relation(fields: [divisionId], references: [id], onDelete: Cascade)

  @@unique([divisionId, name])
  @@map("districts")
}

model Upazila {
  id         String @id @default(cuid())
  districtId String @map("district_id")
  name       String
  nameBn     String @map("name_bn")

  district District @relation(fields: [districtId], references: [id], onDelete: Cascade)

  @@unique([districtId, name])
  @@map("upazilas")
}
